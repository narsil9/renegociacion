# ============================================================
# BROWSER
# ============================================================
# false = browser visible (local dev on MacBook Air)
# true  = headless (production on Mac Mini)
HEADLESS=false

# ============================================================
# CLAVE ÚNICA LOGIN
# ============================================================
CLAVE_UNICA_RUT=12345678-9
CLAVE_UNICA_PASSWORD=tu_clave_unica_aqui

# ============================================================
# PASO 1 - INFORMACIÓN PERSONAL
# ============================================================
# Nombres, apellidos y género son completados automáticamente por el portal (vía RUT)

PERSONA_NACIONALIDAD=Chilena

# Formato: DD/MM/AAAA
PERSONA_FECHA_NACIMIENTO=01/01/1990

# Estado Civil: 1=Soltero(a), 2=Casado(a), 3=Divorciado(a), 4=Viudo(a),
#               5=Con separación judicial, 6=Conviviente Civil, 7=No tiene o no informado
PERSONA_ESTADO_CIVIL=1

# Régimen Patrimonial (solo si Estado Civil = 2 / Casado):
# Dejar vacío si no aplica
PERSONA_REGIMEN_PATRIMONIAL=

# Profesión/Oficio (valor numérico del select, ej: 1=Abogados, 12=Agrónomos, 9999=Otros)
PERSONA_PROFESION_OFICIO=1

# Situación Laboral: 8=Busca trabajo 1era vez, 9=Cesante, 10=Dueño/a de casa,
#                   11=Estudiante, 12=Jubilado/Pensionado, 13=Trabajador dependiente,
#                   14=Trabajador independiente, 15=Ley Protección Empleo, 32767=Sin Información
PERSONA_OCUPACION=13

PERSONA_DIRECCION=Calle Número

# Región (valor numérico: 13=Región Metropolitana, 5=Valparaíso, etc.)
PERSONA_REGION=13

# Comuna (valor numérico: 301=PROVIDENCIA, 279=SANTIAGO, etc.)
PERSONA_COMUNA=279

PERSONA_EMAIL=correo@dominio.com

# Prefijo teléfono: 9=celular, 2=Santiago, 56=internacional, etc.
PERSONA_TELEFONO_PREFIJO=9
PERSONA_TELEFONO=912345678

# ============================================================
# SENTINEL DE CARGA (API Key #1)
# ============================================================
ENABLE_SENTINEL=false
