# ============================================================
# PRODUCCIÓN — lo que el worker (src/worker.ts) necesita
# ============================================================
# Base Supabase donde tu dashboard escribe y el worker lee/escribe.
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key>

# Claude — lee cada documento del cliente (Centinela del Paso 3 + Ingresos del Paso 5).
ANTHROPIC_API_KEY=sk-ant-...

# true = headless (servidor); false = navegador visible (para depurar).
HEADLESS=true

# ============================================================
# OPCIONALES
# ============================================================
# Jobs en paralelo (default 1).
# WORKER_CONCURRENCY=1

# Lectura por documento del Centinela: ACTIVADA por defecto. Poné =false para desactivarla.
# CENTINELA_PER_DOC=false

# Solo si leés las credenciales ClaveÚnica desde un sistema externo por airtable_id.
# En el caso normal, la ClaveÚnica de cada cliente va en la tabla `clients`.
# PROD_SUPABASE_URL=
# PROD_SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# ⚠️ SOLO PARA PRUEBAS — NUNCA en producción
# ============================================================
# Desactivan validaciones críticas; el worker avisa ruidoso si detecta alguna.
# El modo prueba real se controla por job (automation_jobs.dry_run), no acá.
# DRY_RUN=true
# BYPASS_DATE_CHECK=true       # omite el chequeo de antigüedad (<30d) de CMF/certs
# DISABLE_SENTINEL=true        # apaga la detección de acreedores NO-CMF
# FORCE_VISION_MAPEADOR=true

# ============================================================
# CLIENTE DE PRUEBA / CLI LEGACY (tools/index.ts) — no lo usa el worker
# ============================================================
# En producción los datos del Paso 1 y la ClaveÚnica viven en la tabla `clients`
# (los carga tu dashboard). Estas variables solo sirven para correr un caso suelto
# desde la CLI de desarrollo. Enums del portal en supabase/portal_select_values.json.
# CLAVE_UNICA_RUT=12345678-9
# CLAVE_UNICA_PASSWORD=
# PERSONA_NACIONALIDAD=Chilena
# PERSONA_FECHA_NACIMIENTO=01/01/1990   # DD/MM/AAAA
# PERSONA_ESTADO_CIVIL=1                # 1=Soltero(a) 2=Casado(a) 3=Divorciado(a) 4=Viudo(a) …
# PERSONA_REGIMEN_PATRIMONIAL=          # solo si Estado Civil = 2
# PERSONA_PROFESION_OFICIO=1
# PERSONA_OCUPACION=13                  # 13=Trabajador/a dependiente …
# PERSONA_DIRECCION=Calle Número
# PERSONA_REGION=13                     # 13=Región Metropolitana …
# PERSONA_COMUNA=279                    # 279=SANTIAGO …
# PERSONA_EMAIL=correo@dominio.com
# PERSONA_TELEFONO_PREFIJO=9
# PERSONA_TELEFONO=912345678
