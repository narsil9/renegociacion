{
  "name": "renegociacion-automation",
  "version": "1.0.0",
  "description": "Hybrid automation for Superintendencia de Insolvencia portal",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.build.json",
    "worker": "ts-node src/worker.ts",
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"NodeNext\",\"moduleResolution\":\"NodeNext\"}' ts-node --transpile-only casos/paso5_pruebas/unit_tests.ts && TS_NODE_COMPILER_OPTIONS='{\"module\":\"NodeNext\",\"moduleResolution\":\"NodeNext\"}' ts-node --transpile-only casos/paso5_pruebas/run_deterministic.ts && TS_NODE_COMPILER_OPTIONS='{\"module\":\"NodeNext\",\"moduleResolution\":\"NodeNext\"}' ts-node --transpile-only casos/paso5_pruebas/run_renegociacion_docs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^16.4.5",
    "pg": "^8.21.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
